# Dev server port (Create React App)
PORT=3000

# Backend API base URL (the Go server). For local dev this is the local backend;
# in production set it to your Fly.io app URL.
REACT_APP_API_URL=http://localhost:8080

# Public base URL serving the problem assets (imageframes/*).
# Defaults to the still-live original bucket if unset; point at your R2 mirror
# once you have one.
REACT_APP_ASSETS_BASE_URL=https://s3.amazonaws.com/cdn.robovinci.xyz
