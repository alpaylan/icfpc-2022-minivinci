# mini-vinci backend configuration (all values are read from the environment).
# Copy to .env for local use, or set as Fly.io secrets in production.
# Do NOT commit a filled-in .env — it is gitignored.

# --- Database (SQLite) ---
DATABASE_PATH=minivinci.db

# --- HTTP ---
PORT=8080

# --- JWT secrets (CHANGE THESE) ---
JWT_LOGIN_SECRET=change-me-login
JWT_VERIFICATION_SECRET=change-me-verification
JWT_RENEW_PASSWORD_SECRET=change-me-renew
JWT_LOGIN_EXPIRE_HOURS=24

# --- Async / Redis ---
# Eager runs evaluation + email synchronously (no Redis needed). Keep true for
# the simple single-machine deployment.
ASYNC_EAGER=true
# REDIS_ADDRESS=localhost:6379   # only used when ASYNC_EAGER=false

# --- Object storage (S3-compatible; Cloudflare R2) ---
# Endpoint empty => AWS S3. For R2 use https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_REGION=auto
S3_SUBMISSIONS_BUCKET=minivinci-submissions
# S3_SOURCECODE_BUCKET defaults to the submissions bucket if unset
# S3_SOURCECODE_BUCKET=minivinci-submissions
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Public base URL serving problem assets (imageframes/*) and frozen_scoreboard.json.
# Defaults to the still-live original bucket; point this at your R2 public URL once mirrored.
ASSETS_BASE_URL=https://s3.amazonaws.com/cdn.robovinci.xyz

# --- Judge ---
# Working directory of the built Node judge (containing dist/ISLRunner.js).
JUDGE_DIR=../../mini-vinci-judge

# --- Email (AWS SES) ---
# Disabled => new users are auto-verified and password-reset emails are no-ops.
EMAIL_ENABLED=false
# EMAIL_SES_REGION=us-east-1
# EMAIL_FROM=noreply@example.com
# EMAIL_VERIFICATION_URL=https://your-frontend/users/verification/
# EMAIL_RENEW_PASSWORD_URL=https://your-frontend/users/password/renew

# --- Admins (comma-separated emails) ---
# Admins bypass the contest-over submission lock and always see the live scoreboard.
ADMIN_EMAILS=

# --- Logging ---
# Empty LOG_OUTPUT_FILE => stdout (recommended in containers).
LOG_OUTPUT_FILE=
LOG_LEVEL=info
